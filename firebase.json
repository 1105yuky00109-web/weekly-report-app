{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.@(html|js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/auth-action",
        "destination": "/auth-action.html"
      },
      {
        "source": "/api",
        "function": "api"
      },
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "/add-employee",
        "function": "addEmployee"
      },
      {
        "source": "/delete-employee",
        "function": "deleteEmployee"
      },
      {
        "source": "/update-employee",
        "function": "updateEmployee"
      },
      {
        "source": "/check-email",
        "function": "checkEmailRegistered"
      }
    ]
  },
  "functions": {
    "source": "functions"
  },
  "emulators": {
    "hosting": { "port": 5004 },
    "firestore": { "port": 8084 },
    "auth": { "port": 9101 },
    "functions": { "port": 5005 },
    "ui": { "enabled": true, "port": 4004 }
  }
}
